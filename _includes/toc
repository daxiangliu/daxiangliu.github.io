<aside class="sidebar__right">
  <button class="toc-toggle-btn" type="button" aria-expanded="true" aria-label="隐藏目录" title="隐藏目录">
    <i class="fa fa-eye-slash" aria-hidden="true"></i>
    <span class="sr-only toc-toggle-text">隐藏目录</span>
  </button>
  <nav class="toc">
    <header>
      <h4 class="nav__title">
        <i class="fa fa-{{ include.icon | default: 'file-text' }}"></i>
        {{ include.title | default: site.data.ui-text[site.locale].toc_label }}
      </h4>
    </header>
    <ul class="toc__menu"></ul>
  </nav>
</aside>
